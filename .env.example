ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Copy the Sheet ID from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEETS_ID=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY=

# --- Google credentials (choose one approach) ---

# SERVER (Railway / Render / Cloud Run): paste the full JSON content of each file
# Get GOOGLE_CREDENTIALS_JSON from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client → Download JSON
# Get GOOGLE_TOKEN_JSON by running locally: python -c "from conference_capture.auth import get_credentials; get_credentials()"
#   then: cat token.json
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# LOCAL only: path to credentials.json file (used if the env vars above are not set)
# GOOGLE_CREDENTIALS_FILE=credentials.json
